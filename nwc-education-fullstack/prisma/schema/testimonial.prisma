model Testimonial {
  id           String                   @id @default(cuid())
  type         TestimonialType          @default(STUDENT)
  mediaType    MediaType                @default(TEXT_ONLY)
  name         String
  role         String?
  content      String?
  rating       Int?
  avatar       String?
  videoUrl     String?
  url          String?
  isFeatured   Boolean                  @default(false)
  order        Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  status       ContentStatus            @default(DRAFT)
  countries    TestimonialCountry[]
  destinations TestimonialDestination[]
  events       TestimonialEvent[]
  universities TestimonialUniversity[]

  @@index([status])
}
