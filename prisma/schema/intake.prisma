model IntakeSeason {
  id                  String                @id @default(cuid())
  title               String
  subtitle            String?
  description         String?
  intake              IntakeMonth
  year                Int
  backgroundImage     String?
  ctaLabel            String?               @default("Apply Now")
  ctaUrl              String?               @default("/apply-now")
  applicationDeadline DateTime?
  intakeStartDate     DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  status              ContentStatus         @default(DRAFT)
  isGlobal            Boolean               @default(false)
  destinationId       String?
  destination         Destination?          @relation(fields: [destinationId], references: [id])
  countries           IntakeSeasonCountry[]
  intakePages         IntakePage[]

  @@index([intake, year])
  @@index([status])
  @@index([destinationId])
}

model IntakeSeasonCountry {
  id             String       @id @default(cuid())
  intakeSeasonId String
  countryId      String
  country        Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)
  intakeSeason   IntakeSeason @relation(fields: [intakeSeasonId], references: [id], onDelete: Cascade)

  @@unique([intakeSeasonId, countryId])
}

model IntakePageBenefit {
  id           String     @id @default(cuid())
  intakePageId String
  title        String
  description  String?
  icon         String?    // Lucide icon name or custom icon URL
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  intakePage   IntakePage @relation(fields: [intakePageId], references: [id], onDelete: Cascade)
  
  @@index([intakePageId, sortOrder])
}

model IntakePageHowWeHelpItem {
  id           String     @id @default(cuid())
  intakePageId String
  title        String
  description  String?
  icon         String?    // Lucide icon name or custom icon URL
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  intakePage   IntakePage @relation(fields: [intakePageId], references: [id], onDelete: Cascade)
  
  @@index([intakePageId, sortOrder])
}

model IntakePageCountry {
  id           String     @id @default(cuid())
  intakePageId String
  countryId    String
  country      Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  intakePage   IntakePage @relation(fields: [intakePageId], references: [id], onDelete: Cascade)

  @@unique([intakePageId, countryId])
}

model IntakePageUniversity {
  id           String     @id @default(cuid())
  intakePageId String
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  intakePage   IntakePage @relation(fields: [intakePageId], references: [id], onDelete: Cascade)

  @@unique([intakePageId, universityId])
}
