generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["prismaSchemaFolder"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  MANAGER
}

enum ProviderType {
  UNIVERSITY
  GOVERNMENT
  PRIVATE
  EMBASSY
}

enum EventType {
  EXPO
  WEBINAR
  ADMISSION_DAY
  OPEN_DAY
  SEMINAR
  WORKSHOP
}

enum IntakeMonth {
  JANUARY
  MAY
  SEPTEMBER
}

enum StudyLevel {
  FOUNDATION
  BACHELOR
  MASTER
  PHD
  DIPLOMA
  CERTIFICATE
  PATHWAY
}

enum Faculty {
  ENGINEERING
  BUSINESS
  ARTS_HUMANITIES
  SCIENCE
  MEDICINE_HEALTH
  LAW
  EDUCATION
  SOCIAL_SCIENCES
  IT_COMPUTING
  ARCHITECTURE
  AGRICULTURE
  HOSPITALITY_TOURISM
  MEDIA_COMMUNICATION
  OTHER
}

enum ReviewType {
  GMB
  STUDENT
  OTHER
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TestimonialType {
  STUDENT
  REPRESENTATIVE
  GMB
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT_ONLY
}

enum BackgroundType {
  IMAGE
  VIDEO
  YOUTUBE
}
