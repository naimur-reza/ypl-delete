model GlobalOffice {
  id              String                @id @default(cuid())
  name            String                @unique
  subtitle        String?
  slug            String                @unique
  email           String?
  phone           String?
  address         String?
  latitude        Float?
  longitude       Float?
  mapEmbedUrl     String?
  openingHours    Json?
  content         String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  countries       GlobalOfficeCountry[]
}

model Country {
  id                 String                 @id @default(cuid())
  name               String
  slug               String                 @unique
  isoCode            String                 @unique
  flag               String?
  isActive           Boolean                @default(true)
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  accreditation      AccreditationCountry[]
  appointments       Appointment[]
  blogs              BlogCountry[]
  courses            CourseCountry[]
  destinations       DestinationCountry[]
  events             EventCountry[]
  eventRegistrations EventRegistration[]
  faqs               FAQCountry[]
  galleries          GalleryCountry[]
  globalOffices      GlobalOfficeCountry[]
  heroes             HeroCountry[]
  intakeSeasons      IntakeSeasonCountry[]
  leads              Lead[]
  scholarships       ScholarshipCountry[]
  stats              StatCountry[]
  testimonials       TestimonialCountry[]
  universities       UniversityCountry[]
}

model Destination {
  id                 String                   @id @default(cuid())
  name               String
  slug               String                   @unique
  heroTitle          String?
  thumbnail          String?
  heroSubtitle       String?
  whyChoose          String?
  topUniversities    String?
  campusAndCommunity String?
  destinationLife    String?
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  blogs              Blog[]
  courses            Course[]
  countries          DestinationCountry[]
  sections           DestinationSection[]
  essentialStudies   EssentialStudy[]
  events             Event[]
  faqLinks           FAQDestination[]
  intakePages        IntakePage[]
  leads              Lead[]
  scholarships       Scholarship[]
  testimonials       TestimonialDestination[]
  universities       University[]
}

model EssentialStudy {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String?
  content       String?
  destinationId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  destination   Destination @relation(fields: [destinationId], references: [id])

  @@index([destinationId])
}

model DestinationSection {
  id            String      @id @default(cuid())
  title         String
  slug          String
  image         String?
  content       String?
  displayOrder  Int         @default(0)
  isActive      Boolean     @default(true)
  destinationId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([destinationId, slug])
  @@index([destinationId])
}
