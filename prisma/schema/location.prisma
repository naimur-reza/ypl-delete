model GlobalOffice {
  id              String                @id @default(cuid())
  name            String                @unique
  city            String?
  subtitle        String?
  slug            String                @unique
  email           String?
  phone           String?
  address         String?
  mapUrl          String?
  content         String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  bannerImage     String?
  image           String?
  openingHours    Json?
  status          ContentStatus         @default(DRAFT)
  countries       GlobalOfficeCountry[]

  @@index([status])
  @@map("global_offices")
}

model Country {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  isoCode            String                  @unique
  flag               String?
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  status             ContentStatus           @default(DRAFT)
  accreditation      AccreditationCountry[]
  appointments       Appointment[]
  blogs              BlogCountry[]
  courses            CourseCountry[]
  destinations       DestinationCountry[]
  events             EventCountry[]
  eventRegistrations EventRegistration[]
  faqs               FAQCountry[]
  galleries          GalleryCountry[]
  globalOffices      GlobalOfficeCountry[]
  heroes             HeroCountry[]
  intakeSeasons      IntakeSeasonCountry[]
  intakePages        IntakePage[]
  leads              Lead[]
  scholarships       ScholarshipCountry[]
  stats              StatCountry[]
  testimonials       TestimonialCountry[]
  universities       UniversityCountry[]
  essentials         EssentialStudyCountry[]
  services           ServiceCountry[]

  @@index([status])
}

model Destination {
  id                 String                   @id @default(cuid())
  name               String
  slug               String                   @unique
  heroTitle          String?
  thumbnail          String?
  heroSubtitle       String?
  whyChoose          String?
  topUniversities    String?
  campusAndCommunity String?
  destinationLife    String?
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  status             ContentStatus            @default(ACTIVE)
  blogs              Blog[]
  courses            Course[]
  countries          DestinationCountry[]
  sections           DestinationSection[]
  essentialStudies   EssentialStudy[]
  events             Event[]
  faqLinks           FAQDestination[]
  intakePages        IntakePage[]
  leads              Lead[]
  scholarships       Scholarship[]
  testimonials       TestimonialDestination[]
  universities       University[]
  eventDestinations  EventDestination[]

  @@index([status])
}

model EssentialStudy {
  id            String                  @id @default(cuid())
  title         String
  slug          String                  @unique
  description   String?
  content       String?
  destinationId String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  status        ContentStatus           @default(DRAFT)
  destination   Destination             @relation(fields: [destinationId], references: [id])
  countries     EssentialStudyCountry[]

  @@index([destinationId])
  @@index([status])
}

model DestinationSection {
  id            String        @id @default(cuid())
  title         String
  slug          String
  image         String?
  content       String?
  displayOrder  Int           @default(0)
  destinationId String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  status        ContentStatus @default(DRAFT)
  destination   Destination   @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([destinationId, slug])
  @@index([destinationId])
  @@index([status])
}
