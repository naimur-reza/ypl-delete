model Service {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  summary         String?
  content         String?
  image           String?
  icon            String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  heroSubtitle    String?
  heroTitle       String?
  stats           Json?
  status          ContentStatus    @default(ACTIVE)
  isGlobal        Boolean          @default(false)
  countries       ServiceCountry[]

  @@index([status])
}

model Accreditation {
  id        String                 @id @default(cuid())
  name      String
  logo      String?
  website   String?
  sortOrder Int?                   @default(0)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  type      AccreditationType      @default(NEWS)
  status    ContentStatus          @default(DRAFT)
  isGlobal  Boolean                @default(false)
  countries AccreditationCountry[]

  @@index([status])
}

model Career {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  department       String?
  location         String?
  jobType          String?
  jobLocation      String?
  description      String?
  requirements     String?
  responsibilities String?
  benefits         String?
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String?          @default("USD")
  applyUrl         String?
  deadline         DateTime?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  status           ContentStatus    @default(ACTIVE)
  applications     JobApplication[]

  @@index([status])
}

model JobApplication {
  id                String               @id @default(cuid())
  careerId          String
  email             String
  phone             String
  coverLetter       String?
  resumeUrl         String?
  linkedinUrl       String?
  portfolioUrl      String?
  currentCompany    String?
  yearsOfExperience Int?
  expectedSalary    String?
  availableFrom     DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  name              String
  status            JobApplicationStatus @default(PENDING)
  career            Career               @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@index([careerId])
  @@index([email])
  @@index([status])
}

enum JobApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  HIRED
}

enum AccreditationType {
  NEWS
  PARTNER
  ACCREDITATION
}

enum LegalPageType {
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS
}

model LegalPage {
  id        String        @id @default(cuid())
  type      LegalPageType @unique
  title     String
  subtitle  String?
  content   String?       @db.Text
  updatedAt DateTime      @updatedAt
}
