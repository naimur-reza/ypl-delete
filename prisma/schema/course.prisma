model Course {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String?
  duration        String?
  tuitionMin      Float?
  tuitionMax      Float?
  currency        String?         @default("USD")
  sections        Json?
  isFeatured      Boolean         @default(false)
  isActive        Boolean         @default(true)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String?
  updatedBy       String?
  universityId    String
  destinationId   String
  icon            String?
  summary         String?
  studyLevel      StudyLevel?
  faculty         Faculty?
  blogLinks       BlogCourse[]
  destination     Destination     @relation(fields: [destinationId], references: [id])
  university      University      @relation(fields: [universityId], references: [id])
  countries       CourseCountry[]
  intakes         CourseIntake[]
  faqs            FAQCourse[]
  scholarships    Scholarship[]   @relation("CourseToScholarship")

  @@index([universityId])
  @@index([destinationId])
  @@index([isActive])
  @@index([studyLevel])
  @@index([faculty])
}

model CourseIntake {
  id       String      @id @default(cuid())
  courseId String
  intake   IntakeMonth
  course   Course      @relation(fields: [courseId], references: [id])

  @@unique([courseId, intake])
}

model IntakePage {
  id                   String              @id @default(cuid())
  destinationId        String
  intake               IntakeMonth
  title                String
  description          String?
  heroMedia            String?
  eligibility          String?
  timelineJson         Json?
  ctaLabel             String?
  ctaUrl               String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  isActive             Boolean?            @default(true)
  heroCTALabel         String?
  heroCTAUrl           String?
  heroSubtitle         String?
  heroTitle            String?
  metaDescription      String?
  metaKeywords         String?
  metaTitle            String?
  whyChooseDescription String?
  whyChooseTitle       String?
  faqs                 FAQIntakePage[]
  destination          Destination         @relation(fields: [destinationId], references: [id])
  intakePageBenefits   IntakePageBenefit[]

  @@unique([destinationId, intake])
  @@index([isActive])
}
