model University {
  id              String                  @id @default(cuid())
  rankingNumber   Int?
  costOfStudying  String?
  name            String
  slug            String                  @unique
  logo            String?
  thumbnail       String?
  description     String?
  providerType    ProviderType
  isFeatured      Boolean                 @default(false)
  website         String?
  address         String?
  phone           String?
  email           String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  createdBy       String?
  updatedBy       String?
  destinationId   String
  status          ContentStatus           @default(ACTIVE)
  isGlobal        Boolean                 @default(false)
  blogLinks       BlogUniversity[]
  courses         Course[]
  events          Event[]
  faqLinks        FAQUniversity[]
  scholarships    Scholarship[]
  testimonials    TestimonialUniversity[]
  destination     Destination             @relation(fields: [destinationId], references: [id])
  countries       UniversityCountry[]
  detail          UniversityDetail?       @relation("UniversityToDetail")

  @@index([destinationId])
  @@index([isFeatured])
  @@index([status])
}

model UniversityDetail {
  id                  String        @id @default(cuid())
  universityId        String        @unique
  overview            String
  ranking             String?
  tuitionFees         String?
  famousFor           String?
  servicesHeading     String?
  servicesDescription String?
  servicesImage       String?
  entryRequirements   String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  accommodation       String?
  accommodationImage  String?
  description         String?
  status              ContentStatus @default(DRAFT)
  university          University    @relation("UniversityToDetail", fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@index([status])
}
