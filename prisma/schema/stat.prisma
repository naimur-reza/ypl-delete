// Stat Model for managing dynamic statistics displayed across the website
model Stat {
  id          String   @id @default(cuid())
  title       String   // e.g., "Located in", "End to End", "500+"
  subtitle    String   // e.g., "15+ Countries", "Services", "Universities Covered"
  icon        String?  // Lucide icon name: "MapPin", "ArrowLeftRight", etc.
  color       String?  // Tailwind color: "pink", "emerald", "blue", "indigo"
  
  // Categorization
  section     String   // "about", "hero", "faq", "event" - where to display
  slideIndex  Int?     // For hero slider stats - which slide (0, 1, 2, etc.)
  
  // Ordering & Status
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  
  // Optional country relation for country-specific stats
  countries   StatCountry[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([section])
  @@index([isActive])
}

model StatCountry {
  id        String  @id @default(cuid())
  statId    String
  countryId String
  
  stat      Stat    @relation(fields: [statId], references: [id], onDelete: Cascade)
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  
  @@unique([statId, countryId])
}
