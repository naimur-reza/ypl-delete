model FAQ {
  id           String           @id @default(cuid())
  question     String
  answer       String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    String?
  updatedBy    String?
  isGlobal     Boolean          @default(false)
  countries    FAQCountry[]
  courses      FAQCourse[]
  destinations FAQDestination[]
  events       FAQEvent[]
  intakePages  FAQIntakePage[]
  scholarships FAQScholarship[]
  universities FAQUniversity[]
}
