model FAQ {
  id                          String           @id @default(cuid())
  question                    String
  answer                      String
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  createdBy                   String?
  updatedBy                   String?
  isGlobal                    Boolean          @default(false)
  showOnUniversitiesMainPage  Boolean          @default(false)
  showOnCoursesMainPage       Boolean          @default(false)
  showOnEventsMainPage        Boolean          @default(false)
  showOnScholarshipsMainPage  Boolean          @default(false)
  showOnDestinationsMainPage  Boolean          @default(false)
  showOnIntakePagesMainPage   Boolean          @default(false)
  status                      ContentStatus    @default(DRAFT)
  countries                   FAQCountry[]
  courses                     FAQCourse[]
  destinations                FAQDestination[]
  events                      FAQEvent[]
  intakePages                 FAQIntakePage[]
  scholarships                FAQScholarship[]
  universities                FAQUniversity[]

  @@index([status])
}
