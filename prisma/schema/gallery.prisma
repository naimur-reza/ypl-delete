model Gallery {
  id          String           @id @default(cuid())
  title       String
  description String?
  image       String
  type        GalleryType      @default(VISA_SUCCESS)
  sortOrder   Int?             @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  countries   GalleryCountry[]
}

enum GalleryType {
  VISA_SUCCESS
  REPRESENTATIVE
  EVENT
  OFFICE
  STUDENT
}
